@page "/document-store"
@attribute [Authorize(Policy = Permissions.Documents.View)]
@inject Microsoft.Extensions.Localization.IStringLocalizer<DocumentStore> _localizer
@using BlazorHero.CleanArchitecture.Application.Features.Documents.Queries.GetAll
@using BlazorHero.CleanArchitecture.Domain.Enums
@using BlazorHero.CleanArchitecture.Shared.Constants.Application

<style>
    .mud-table-container {
        overflow: auto;
    }
</style>

<HeroTitle Title="@_localizer["Document Store"]" Description="@_localizer["Browse Available Documents."]" />
@if (!_loaded)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudTable Elevation="25" ServerData="@(new Func<TableState, Task<TableData<GetAllDocumentsResponse>>>(ServerReload))" Hover="true" Dense="@_dense" Bordered="@_bordered" Striped="@_striped" @ref="_table">
        <ToolBarContent>
            <div class="justify-center mud-text-align-center">
                @if (_canCreateDocuments)
                {
                    <MudButton DisableElevation Variant="Variant.Filled" Color="Color.Primary" @onclick="@(() => InvokeModal(0))" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Surface">@_localizer["Create"]</MudButton>
                    <MudButton DisableElevation Variant="Variant.Filled" OnClick="@(() => OnSearch(""))" StartIcon="@Icons.Material.Filled.Refresh" IconColor="Color.Surface" Color="Color.Secondary">@_localizer["Reload"]</MudButton>
                }
                else
                {
                    <MudButton DisableElevation Variant="Variant.Filled" OnClick="@(() => OnSearch(""))" StartIcon="@Icons.Material.Filled.Refresh" IconColor="Color.Surface" Color="Color.Secondary">@_localizer["Reload"]</MudButton>
                }
            </div>
            <MudSpacer />
            <MudSelect T="DocumentStatus?" Label="@_localizer["Status"]" Value="@_statusFilter" ValueChanged="OnStatusFilterChanged" Style="min-width: 160px; margin-right: 16px;">
                <MudSelectItem T="DocumentStatus?" Value="@((DocumentStatus?)null)">@_localizer["All"]</MudSelectItem>
                <MudSelectItem T="DocumentStatus?" Value="@((DocumentStatus?)DocumentStatus.Draft)">@_localizer["Draft"]</MudSelectItem>
                <MudSelectItem T="DocumentStatus?" Value="@((DocumentStatus?)DocumentStatus.PendingReview)">@_localizer["Pending Review"]</MudSelectItem>
                <MudSelectItem T="DocumentStatus?" Value="@((DocumentStatus?)DocumentStatus.Published)">@_localizer["Published"]</MudSelectItem>
                <MudSelectItem T="DocumentStatus?" Value="@((DocumentStatus?)DocumentStatus.Rejected)">@_localizer["Rejected"]</MudSelectItem>
                <MudSelectItem T="DocumentStatus?" Value="@((DocumentStatus?)DocumentStatus.Archived)">@_localizer["Archived"]</MudSelectItem>
            </MudSelect>
            @if (_canSearchDocuments)
            {
                <MudTextField T="string" ValueChanged="@(s=>OnSearch(s))" Placeholder="@_localizer["Search"]" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            }
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel T="GetAllDocumentsResponse" SortLabel="documentIdField">@_localizer["Id"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="GetAllDocumentsResponse" SortLabel="documentTitleField">@_localizer["Title"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="GetAllDocumentsResponse" SortLabel="documentDescriptionField">@_localizer["Description"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="GetAllDocumentsResponse" SortLabel="documentDocumentTypeField">@_localizer["Document Type"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="GetAllDocumentsResponse" SortLabel="documentIsPublicField">@_localizer["Is Public"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="GetAllDocumentsResponse" SortLabel="documentStatusField">@_localizer["Status"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="GetAllDocumentsResponse" SortLabel="documentDateCreatedField">@_localizer["Date Created"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="GetAllDocumentsResponse" SortLabel="documentOwnerField">@_localizer["Owner"]</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right">@_localizer["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Id">@context.Id</MudTd>
            <MudTd DataLabel="Title">
                <MudHighlighter Text="@context.Title" HighlightedText="@_searchString" />
            </MudTd>
            <MudTd DataLabel="Description">
                <MudHighlighter Text="@context.Description" HighlightedText="@_searchString" />
            </MudTd>
            <MudTd DataLabel="DocumentType">
                <MudHighlighter Text="@context.DocumentType" HighlightedText="@_searchString" />
            </MudTd>
            <MudTd DataLabel="IsPublic"><MudCheckBox @bind-Checked="@context.IsPublic" ReadOnly="true" Color="Color.Secondary" /></MudTd>
            <MudTd DataLabel="Status">
                @{
                    var (statusColor, statusIcon) = GetStatusDisplay(context.Status);
                    var showRejection = context.Status == DocumentStatus.Rejected && !string.IsNullOrWhiteSpace(context.RejectionReason);
                }
                @if (showRejection)
                {
                    <MudTooltip Text="@context.RejectionReason">
                        <MudChip Color="@statusColor" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.Flag">
                            @context.Status
                        </MudChip>
                    </MudTooltip>
                }
                else
                {
                    <MudChip Color="@statusColor" Variant="Variant.Filled" Size="Size.Small" Icon="@statusIcon">
                        @context.Status
                    </MudChip>
                }
                @if (showRejection)
                {
                    <div class="mt-1">
                        <MudText Typo="Typo.caption" Color="Color.Error">
                            @_localizer["Rejected:"] @TruncateReason(context.RejectionReason)
                        </MudText>
                    </div>
                }
            </MudTd>
            <MudTd DataLabel="Date Created">@context.CreatedOn</MudTd>
            <MudTd DataLabel="Owner">
                @if (context.CreatedBy == CurrentUserId)
                    {
                    <MudButton Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.Face"
                               IconColor="Color.Secondary"
                               Size="Size.Small"
                               Color="Color.Surface"
                               Link="/account">
                        @_localizer["you"]
                    </MudButton>
                    }
            </MudTd>
            <MudTd DataLabel="Actions" Style="text-align: right">
                @{
                    var hasActions = _canEditDocuments || _canDeleteDocuments || _canViewDocumentExtendedAttributes || _canApproveDocuments || _canRejectDocuments || _canArchiveDocuments;
                }
                @if (hasActions)
                    {
                    <MudMenu Label="@_localizer["Actions"]" Variant="Variant.Filled" DisableElevation="true" EndIcon="@Icons.Filled.KeyboardArrowDown" IconColor="Color.Secondary" Direction="Direction.Left" OffsetX="true">
                        @if (_canViewDocumentExtendedAttributes)
                            {
                            <MudMenuItem @onclick="@(() => ManageExtendedAttributes(@context.Id))">@_localizer["Manage Extended Attributes"]</MudMenuItem>
                            }
                        @if (context.CreatedBy == CurrentUserId)
                            {
                            @if (_canEditDocuments)
                                {
                                <MudMenuItem @onclick="@(() => InvokeModal(@context.Id))">@_localizer["Edit"]</MudMenuItem>
                                }
                            @if (_canDeleteDocuments)
                                {
                                <MudMenuItem @onclick="@(() => Delete(@context.Id))">@_localizer["Delete"]</MudMenuItem>
                                }
                            }
                        @if (context.Status == DocumentStatus.Draft || context.Status == DocumentStatus.Rejected)
                            {
                            @if (_canEditDocuments && context.CreatedBy == CurrentUserId)
                                {
                                <MudMenuItem @onclick="@(() => SubmitForReview(@context.Id))">@_localizer["Submit for Review"]</MudMenuItem>
                                }
                            }
                        @if (context.Status == DocumentStatus.PendingReview)
                            {
                            @if (_canApproveDocuments)
                                {
                                <MudMenuItem @onclick="@(() => Approve(@context.Id))">@_localizer["Approve"]</MudMenuItem>
                                }
                            @if (_canRejectDocuments)
                                {
                                <MudMenuItem @onclick="@(() => OpenRejectDialog(@context.Id))">@_localizer["Reject"]</MudMenuItem>
                                }
                            }
                        @if (context.Status == DocumentStatus.Published || context.Status == DocumentStatus.Draft || context.Status == DocumentStatus.Rejected)
                            {
                            @if (_canArchiveDocuments)
                                {
                                <MudMenuItem @onclick="@(() => Archive(@context.Id))">@_localizer["Archive"]</MudMenuItem>
                                }
                            }
                        <MudMenuItem Link="@context.URL" Disabled="@(string.IsNullOrWhiteSpace(context.URL))" Target="_blank">@_localizer["Download"]</MudMenuItem>
                    </MudMenu>
                    }
                    else
                    {
                    <MudButton Variant="Variant.Filled"
                               DisableElevation="true"
                               StartIcon="@Icons.Material.Filled.DoNotTouch"
                               IconColor="Color.Secondary"
                               Size="Size.Small"
                               Color="Color.Surface">
                        @_localizer["No Allowed Actions"]
                    </MudButton>
                    }
            </MudTd>
        </RowTemplate>
        <FooterContent>
            <MudSwitch @bind-Checked="@_dense" Color="Color.Secondary" Style="margin-left: 5px;">@_localizer["Dense"]</MudSwitch>
            <MudSwitch @bind-Checked="@_striped" Color="Color.Tertiary" Style="margin-left: 5px;">@_localizer["Striped"]</MudSwitch>
            <MudSwitch @bind-Checked="@_bordered" Color="Color.Warning" Style="margin-left: 5px;">@_localizer["Bordered"]</MudSwitch>
        </FooterContent>
        <PagerContent>
            <TablePager />
        </PagerContent>
    </MudTable>
}